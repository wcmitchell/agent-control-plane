*.so
*.egg-info/
*.egg
.installed.cfg
MANIFEST
dist/
build/
wheels/
.Python
develop-eggs/
eggs/
.eggs/
sdist/
htmlcov/
.tox/
.coverage
.coverage.*
.cache
.pytest_cache/
.hypothesis/
nosetests.xml
coverage.xml
*.cover
pip-log.txt
pip-delete-this-directory.txt
*.mo
*.pot

# Go
vendor/

# SDK binaries (build artifacts, not source)
**/ambient-sdk-generator
**/examples/examples

# Node / Frontend
node_modules/
.next/
components/frontend/.next/

# Virtual environments
.venv*/
env/
venv/
ENV/
env.bak/
venv.bak/

# Environment files
.env
.env.local
components/frontend/.env.local
.env.uat
.dev-bootstrap.env

# Build artifacts and logs
*.log
!components/**/*.log

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE / AI assistant configuration
.cursor/
.tessl/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Claude Code
.claude/settings.local.json
.claude/worktrees/
.claude/skills/
.claude/commands/

# Beads issue tracker (local Dolt DB, passive export)
.beads/issues.jsonl

# Git worktrees
.worktrees/

# CodeRabbit triage raw data (metrics/ is committed, data/ is transient)
scripts/coderabbit-triage/data/

# mkdocs
/site
docs/_build/

# E2E / Cypress testing
tests/cypress/.env.test
tests/cypress/.env
tests/cypress/.env.local
tests/cypress/node_modules/
tests/cypress/cypress/screenshots/
tests/cypress/cypress/videos/

# Langfuse credentials
tests/infra/.env.langfuse
tests/infra/langfuse/.env.langfuse-keys

# Design / spike artifacts (transient)
.design/
.playwright-mcp/
.stories/
.testplans/
.spikes/

# Test reporting
logs/
reports/

# Security scan artifacts
.security-scan/
.security-scan.zip

# Feedback loop runtime state
scripts/feedback-loop/.last-run

# SDK version bump transient output
.sdk-bump-output/

# Secrets (use .example templates instead)
**/minio-credentials-secret.yaml
**/postgresql-credentials-secret.yaml
**/unleash-credentials-secret.yaml

# One-off analysis and experiments
repomix-analysis/
Prompts/
hack/

# Personal exports
*.csv
components/credential-sidecars/entrypoint/credential-entrypoint
components/credential-sidecars/entrypoint/entrypoint


# APM (Agent Package Manager)
apm_modules/
apm.lock.yaml
.local/

# Local creds
vertex.json
